rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função helper - verifica se é admin
    // Admin = email do fundador OU usuário com role 'admin' no Firestore
    // OBS: o mesmo e-mail está centralizado no frontend em src/lib/auth.ts (FOUNDER_EMAIL).
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'fernandomariodasmartins@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ========== USERS ==========
    match /users/{userId} {
      allow read: if true; // Perfil público
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ========== ARTICLES ==========
    match /articles/{articleId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ========== CULTURE ==========
    match /culture/{cultureId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ========== HEALTH GUIDES ==========
    match /health_guides/{guideId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ========== EVENTS ==========
    match /events/{eventId} {
      // Leitura pública para eventos aprovados
      allow read: if resource.data.status == 'approved' || isAdmin();
      
      // Criação apenas pelo agent (via Admin SDK) ou admin
      allow create: if isAdmin() || 
                    (isSignedIn() && request.resource.data.publishedBy == 'agent');
      
      allow update, delete: if isAdmin();
    }

    // ========== SAFE SPACES ==========
    match /safe_spaces/{spaceId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Espaços cadastrados pelo admin e conteúdo editorial do guia.
    match /places/{placeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /safe_space_overrides/{spaceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Indicações públicas aguardam análise; nunca ficam públicas diretamente.
    match /safe_space_suggestions/{suggestionId} {
      allow create: if request.resource.data.keys().hasOnly([
          'name', 'category', 'address', 'city', 'state', 'description',
          'website', 'contactName', 'contactEmail', 'status', 'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 120
        && request.resource.data.category is string
        && request.resource.data.address is string
        && request.resource.data.address.size() >= 5
        && request.resource.data.address.size() <= 200
        && request.resource.data.city is string
        && request.resource.data.city.size() >= 2
        && request.resource.data.city.size() <= 80
        && request.resource.data.state is string
        && request.resource.data.state.size() == 2
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 10
        && request.resource.data.description.size() <= 1000
        && request.resource.data.website is string
        && request.resource.data.website.size() <= 300
        && request.resource.data.contactName is string
        && request.resource.data.contactName.size() <= 100
        && request.resource.data.contactEmail is string
        && request.resource.data.contactEmail.size() >= 5
        && request.resource.data.contactEmail.size() <= 200
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }

    // Avaliações são autenticadas e passam pela curadoria.
    match /safe_space_reviews/{reviewId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }

    // Uma confirmação por usuário e por local.
    match /safe_space_verifications/{verificationId} {
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && verificationId == request.resource.data.spaceSlug + '_' + request.auth.uid
        && request.resource.data.verified == true
        && request.resource.data.createdAt == request.time;
      allow read, delete: if isAdmin();
    }

    // Reportes ficam privados para proteger quem denunciou.
    match /safe_space_reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.details is string
        && request.resource.data.details.size() >= 10
        && request.resource.data.details.size() <= 1000
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }

    // Conteúdo base público com edição restrita ao admin.
    match /culture_overrides/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /legal_guide_overrides/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /queer_route_overrides/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site_sections/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blocos editoriais adicionais exibidos nas páginas públicas.
    match /page_blocks/{blockId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ========== FORUM TOPICS ==========
    match /forum_topics/{topicId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.author_id) || isAdmin();
      allow delete: if isAdmin();
    }

    // ========== FORUM REPLIES ==========
    match /forum_replies/{replyId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.author_id) || isAdmin();
      allow delete: if isOwner(resource.data.author_id) || isAdmin();
    }

    // ========== MENTOR PROFILES ==========
    match /mentor_profiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 2
        && request.resource.data.displayName.size() <= 80
        && request.resource.data.bio is string
        && request.resource.data.bio.size() >= 30
        && request.resource.data.bio.size() <= 600
        && request.resource.data.topics is list
        && request.resource.data.status in ['available', 'paused'];
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ========== MENTORSHIP ==========
    match /mentorship/{mentorshipId} {
      allow read: if isSignedIn() && 
                  (resource.data.mentor_id == request.auth.uid || 
                   resource.data.mentee_id == request.auth.uid || 
                   isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.mentee_id == request.auth.uid
        && request.resource.data.mentor_id is string
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 600
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time;
      allow update: if isSignedIn() && 
                   (resource.data.mentor_id == request.auth.uid || 
                    resource.data.mentee_id == request.auth.uid || 
                    isAdmin());
      allow delete: if isAdmin();
    }

    // Participação privada em grupos temáticos.
    match /support_group_memberships/{membershipId} {
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && membershipId == request.resource.data.groupId + '_' + request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.joinedAt == request.time;
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ========== AGENT LOGS (apenas Admin SDK) ==========
    match /agentLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Apenas via Admin SDK
    }
    
    match /agentReports/{reportId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ========== COLUMNISTS ==========
    match /columnists/{columnistId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Qualquer coleção não declarada acima permanece bloqueada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
