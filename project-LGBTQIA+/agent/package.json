{
  "name": "lgbtqia-event-agent",
  "version": "1.0.0",
  "description": "Agente autônomo para buscar e publicar eventos LGBTQIA+ no Portal",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/cli/index.ts",
    "run": "tsx src/run-agent.ts",
    "scrape": "tsx src/cli/index.ts scrape",
    "test-scrape": "tsx src/scrape-only.ts",
    "process": "tsx src/cli/index.ts process",
    "seed": "tsx src/seed/seed-content.ts",
    "seed:dry": "tsx src/seed/seed-content.ts --dry-run",
    "test": "vitest"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "openai": "^4.28.0",
    "puppeteer": "^22.0.0",
    "dotenv": "^16.4.0",
    "date-fns": "^3.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
