{
  "name": "portal-lgbtqia-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && node scripts/generate-seo.mjs prepare && vite build && node scripts/generate-seo.mjs finalize && npm run seo:check",
    "seo:check": "node scripts/check-seo.mjs",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit --project tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run type-check && npm run lint && npm run test",
    "skill:sync": "node scripts/sync-agent-skills.mjs",
    "skill:check": "node scripts/check-agent-skills.mjs",
    "mcp:dev": "tsx mcp/portal-lgbtqia-knowledge-mcp/index.ts",
    "mcp:type-check": "tsc -p tsconfig.mcp.json --noEmit",
    "mcp:test": "vitest run -c vitest.mcp.config.ts",
    "registry:validate": "tsx scripts/validate-trust-registry.ts",
    "registry:prepare-reviews": "tsx scripts/prepare-registry-review-packets.ts",
    "registry:check-reviews": "tsx scripts/check-registry-reviews.ts",
    "registry:prepare-v2-reattestation": "tsx scripts/prepare-v2-reattestation.ts",
    "registry:audit-administrative-mutations": "tsx scripts/audit-administrative-mutations.ts",
    "registry:plan-promotion": "tsx scripts/plan-registry-promotion.ts",
    "registry:evaluate-promotion": "tsx scripts/evaluate-registry-promotion.ts",
    "registry:report": "tsx scripts/generate-trust-registry-report.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "dompurify": "^3.2.6",
    "firebase": "12.0.0",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.469.0",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "react-i18next": "^15.6.0",
    "react-router-dom": "^7.6.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jiti": "^2.6.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "source-map": "^0.7.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "unplugin-auto-import": "^19.3.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.10"
  }
}
